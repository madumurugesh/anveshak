              "raw": "{\n  \"id\": \"bbbbbbbb-0000-0000-0000-000000000003\",\n  \"date\": \"2026-03-07\",\n  \"detector_type\": \"DISTRICT_ROLLUP\",\n  \"level\": \"DISTRICT\",\n  \"pincode\": null,\n  \"block\": null,\n  \"district\": \"Villupuram\",\n  \"state\": \"Tamil Nadu\",\n  \"scheme_id\": \"PM_KISAN\",\n  \"severity\": \"HIGH\",\n  \"score\": 0.44,\n  \"no_pct\": 0.44,\n  \"baseline_no_pct\": 0.21,\n  \"total_responses\": 1920,\n  \"affected_beneficiaries\": 3400,\n  \"raw_data\": {\n    \"flagged_blocks\": [\"Vikravandi\", \"Ulundurpet\", \"Kallakurichi\"],\n    \"district_no_pct\": 0.44,\n    \"threshold\": 0.40,\n    \"min_flagged_blocks\": 3\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Tests the DISTRICT_ROLLUP detector type — multiple blocks simultaneously exceeding NO% threshold."
          },
          "response": []
        },
        {
          "name": "Classify Single — DUPLICATE_BENEFICIARY (MEDIUM)",
          "request": {
            "method": "POST",
            "header": [
