            "description": "Expected: `400 Bad Request` — multiple validation errors:\n- `date` missing\n- `level` missing\n- `severity` missing\n- `district` missing\n- `scheme_id` invalid value\n- `no_pct` out of range (must be 0.0–1.0)"
          },
          "response": [
            {
              "name": "400 Validation Error",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
