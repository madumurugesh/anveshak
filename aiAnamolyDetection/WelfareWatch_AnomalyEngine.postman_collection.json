              "raw": "{\n  \"id\": \"bbbbbbbb-0000-0000-0000-000000000002\",\n  \"date\": \"2026-03-07\",\n  \"detector_type\": \"SILENCE\",\n  \"level\": \"PINCODE\",\n  \"pincode\": \"603002\",\n  \"block\": \"Madurantakam\",\n  \"district\": \"Chengalpattu\",\n  \"state\": \"Tamil Nadu\",\n  \"scheme_id\": \"OLD_AGE_PENSION\",\n  \"severity\": \"HIGH\",\n  \"score\": 0.77,\n  \"no_pct\": null,\n  \"baseline_no_pct\": null,\n  \"total_responses\": 3,\n  \"affected_beneficiaries\": 87,\n  \"raw_data\": {\n    \"expected_responses\": 26,\n    \"actual_responses\": 3,\n    \"silence_ratio\": 0.885,\n    \"threshold\": 0.60\n  }\n}",
              "options": { "raw": { "language": "json" } }
